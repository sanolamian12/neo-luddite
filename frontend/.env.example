# 프론트 환경변수 (마스터설계 §3-2). frontend/.env.local 로 복사해 채운다.
# 실제 .env.local 은 gitignore — 커밋 금지.

# Supabase (브라우저는 anon key + RLS)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Seam A Python 백엔드 (하이브리드 챗) 접점 — C 가 배포 후 확정
NEXT_PUBLIC_API_BASE=http://localhost:8000

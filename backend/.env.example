# Seam A — Upstage Solar API. Copy to `.env` and fill the real key.
# The real .env is gitignored — never commit the key.
UPSTAGE_API_KEY=up_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
UPSTAGE_BASE_URL=https://api.upstage.ai/v1
UPSTAGE_CHAT_MODEL=solar-pro3
UPSTAGE_EMBED_QUERY_MODEL=embedding-query
UPSTAGE_EMBED_PASSAGE_MODEL=embedding-passage

# Supabase (마스터설계 §3-2) — 서버는 service role 키(전권, RLS 우회). 절대 프론트에 노출 금지.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
# Workstream B — RAG 는 Postgres 직결(pgvector). 대시보드 → Settings → Database →
# Connection string(풀러)을 그대로. 없으면 RAG 자동 비활성(baseline).
SUPABASE_DB_URL=postgresql://postgres.xxxxxxxxxxxx:PASSWORD@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres
# CORS 허용 오리진 (콤마 구분) — 프론트 배포 도메인. C 가 프로덕션 값 확정.
CORS_ORIGINS=http://localhost:3000

# ── RAG 스위치 (임팩트 측정) ──────────────────────────────────────────────────
RAG_ENABLED=1         # 0 → baseline(근거 없음). ?rag=false 로 요청 단위 오버라이드도 가능.
RAG_TOP_K=5
RAG_MIN_SCORE=0.50    # 이 코사인 유사도 미만 컷(0=컷 없음). 0.50 근거: 학습된 질문 top1 최저
                      # 0.599 vs 도메인 밖 최고 0.471 사이. 컷이 없으면 무관한 질의도 top-k 를
                      # 그대로 받아 근거 없이 단정한다(예: 태양광 세액공제 → 오답).
# UPSTAGE_EMBED_DIM=4096  # rag.passages.embedding 차원과 반드시 일치(기본 4096)

# Seam A — Upstage Solar API. Copy to `.env` and fill the real key.
# The real .env is gitignored — never commit the key.
UPSTAGE_API_KEY=up_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
UPSTAGE_BASE_URL=https://api.upstage.ai/v1
UPSTAGE_CHAT_MODEL=solar-pro3
UPSTAGE_EMBED_QUERY_MODEL=embedding-query
UPSTAGE_EMBED_PASSAGE_MODEL=embedding-passage

# Supabase (마스터설계 §3-2) — 서버는 service role 키(전권, RLS 우회). 절대 프론트에 노출 금지.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
# CORS 허용 오리진 (콤마 구분) — 프론트 배포 도메인. C 가 프로덕션 값 확정.
CORS_ORIGINS=http://localhost:3000

# ── Seam A 백엔드 프로덕션 env (Oracle 춘천) ──────────────────────────────
# 이 파일을 서버의  /opt/neo-luddite/backend/.env  로 복사해 값을 채운다.
# main.py 가 backend/.env 를 load_dotenv 로 읽는다. gitignore — 절대 커밋 금지.

# ── Upstage (국산 · 필수) ───────────────────────────────────────────────
UPSTAGE_API_KEY=            # ⚠️ 필수. 로컬 backend/.env 값 그대로.
UPSTAGE_BASE_URL=https://api.upstage.ai/v1
UPSTAGE_CHAT_MODEL=solar-pro3
# 임베딩(기본값 있으면 생략 가능) — 로컬과 동일하게 맞출 것
UPSTAGE_EMBED_QUERY_MODEL=embedding-query
UPSTAGE_EMBED_PASSAGE_MODEL=embedding-passage

# ── Supabase Postgres 직결 (RAG 저장/검색 · 필수) ────────────────────────
# Supabase 대시보드 → Project Settings → Database → Connection string.
# ⚠️ Session/Transaction "풀러(pooler)" 문자열을 쓸 것(직결보다 안정적).
#    비밀번호에 특수문자가 있으면 URL 그대로 두고 SUPABASE_DB_PASSWORD 로 따로 준다
#    ([YOUR-PASSWORD] placeholder 자동 치환).
SUPABASE_DB_URL=postgresql://postgres.hvnvxfakdhhbakdjkxos:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres
SUPABASE_DB_PASSWORD=       # DB 비밀번호 raw (특수문자 인코딩 신경 안 써도 됨)

# ── CORS (프론트 Vercel 도메인 · 필수) ──────────────────────────────────
# Vercel 배포 후 확정되는 도메인. 콤마로 여러 개 가능(프리뷰 도메인 포함 시).
CORS_ORIGINS=https://neo-luddite.vercel.app

# ── RAG 튜닝(선택 · 기본값 있음) ─────────────────────────────────────────
RAG_ENABLED=true
# RAG_TOP_K=5
# RAG_MIN_SCORE=0.3
